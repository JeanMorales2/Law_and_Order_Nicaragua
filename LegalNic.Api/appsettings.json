{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=LegalNicDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Billing": {
    "DefaultCommissionRate": 0.05
  },
  "Auth": {
    "Issuer": "LegalNic.Api",
    "Audience": "LegalNic.Mobile",
    "SigningKey": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_FOR_PRODUCTION_2026",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Notifications": {
    "ProviderName": "MailKit",
    "FromEmail": "no-reply@legalnic.local",
    "FromName": "LegalNic",
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "UseStartTls": true,
    "SmtpUsername": "smtp-user",
    "SmtpPassword": "CHANGE_ME",
    "ChatEmailThrottleMinutes": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
